# Optional: enable Neon Postgres as persistent blog database.
# If not set, app falls back to src/data/blogs.json.
DATABASE_URL=


# Optional: enable Cloudinary for image uploads.
# If missing, uploads fall back to local /public/uploads storage.
CLOUDINARY_CLOUD_NAME=


CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Site URL used for metadata/sitemap canonical links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
